    "prisma": "^5.14.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "5.5.4",
    "vitest": "^1.5.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
