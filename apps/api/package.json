{
  "name": "@webanwendung/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src test --max-warnings=0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --check .",
    "import": "node dist/importer/noaa.js"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@prisma/client": "^5.14.0",
    "@webanwendung/shared": "workspace:*",
    "dotenv": "^17.3.1",
    "fastify": "^4.26.2",
    "lru-cache": "^10.2.2",
    "pino": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "@vitest/coverage-v8": "^1.5.3",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5",
    "vitest": "^1.5.3"
  }
}