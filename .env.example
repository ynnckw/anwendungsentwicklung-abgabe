# Verbindung zur lokalen Datenbank
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ghcn?schema=public

# Next.js Server/SSR (läuft im Container → api-Service)
API_BASE_URL=http://api:3001

# API-URL für den Browser
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# CORS (API erlaubt Requests vom Web)
WEB_ORIGIN=http://localhost:3000

# API Cache
CACHE_TTL_MINUTES=10
CACHE_MAX_ENTRIES=500

# Offline Demo Seed (pre-aggregated PUBLIC-schema DB dump)
# - OFFLINE_SEED_ENABLED: 1=Datenbank beim Start aus dem Archiv wiederherstellen, 0=überspringen
# - OFFLINE_SEED_FORCE: 1=Wiederherstellung erzwingen, auch wenn Daten vorhanden sind
# - OFFLINE_SEED_FILE: Pfad innerhalb des Containers (das Repository-Root ist unter /repo eingebunden)
OFFLINE_SEED_ENABLED=1
OFFLINE_SEED_FORCE=0
OFFLINE_SEED_FILE=/repo/seed/offline-demo-db.sql.gz

# NOAA Importer (Docker Compose: importer-Service)
# - NOAA_IMPORT_ENABLED: 1=an, 0=aus
# - NOAA_IMPORT_FORCE: 1=erzwingt Neuimport (Aggregate werden vorher gelöscht)
# - NOAA_PURGE_SYNTHETIC: 1=löscht synthetische Seed-Daten nach erfolgreichem Import, 0=behalten
# - NOAA_END_YEAR: letztes Jahr, bis zu dem importiert wird
NOAA_IMPORT_ENABLED=0
NOAA_IMPORT_FORCE=0
NOAA_PURGE_SYNTHETIC=1
NOAA_END_YEAR=2025